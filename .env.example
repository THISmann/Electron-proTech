# proTech Solaire – Variables d'environnement Docker
# Copier en .env et adapter les mots de passe :
#   cp .env.example .env

MYSQL_ROOT_PASSWORD=change-me-root-password
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me-wp-password
WORDPRESS_DB_NAME=wordpress
WORDPRESS_TABLE_PREFIX=wp_

# Optionnel : URL du site (à configurer aussi dans WP Admin > Réglages après 1ère visite)
# WORDPRESS_CONFIG_EXTRA="define('WP_HOME','http://localhost'); define('WP_SITEURL','http://localhost');"
